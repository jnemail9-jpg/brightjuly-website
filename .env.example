# Public Turnstile site key (safe to expose). Used by the competition form widget.
# Default in code falls back to the Cloudflare TEST site key ("always passes").
# Replace with the real site key for production.
PUBLIC_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# Server-side secrets are NOT set here. For local dev they live in `.dev.vars`;
# for production set them in the Cloudflare Pages dashboard:
#   TURNSTILE_SECRET_KEY      (Turnstile siteverify)
#   BREVO_API_KEY             (Brevo transactional email + contacts)
#
# Non-secret Brevo config lives in wrangler.toml [vars]:
#   BREVO_SENDER_NAME, BREVO_SENDER_EMAIL, BREVO_MARKETING_LIST_ID
#
# D1 binding (DB) and its database_id are in wrangler.toml. Create the real DB with:
#   wrangler d1 create brightjuly-entries
# then replace the placeholder database_id and apply migrations:
#   wrangler d1 migrations apply brightjuly-entries --remote
