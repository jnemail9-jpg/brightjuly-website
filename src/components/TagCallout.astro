---
// "Post. Tag. Enter." instruction callout, reused across several sections.
export interface Props {
  variant?: "light" | "dark";
  /** Where the "form" link in step 4 points. Defaults to the promotion entry form. */
  formHref?: string;
}
const { variant = "light", formHref = "/promotion#entry" } = Astro.props;
---

<div class:list={["bj-tag-callout", { dark: variant === "dark" }]}>
  <p class="bj-tc-title">Post. Tag. Enter.</p>
  <ol>
    <li><span class="num">1</span><span>Share your outdoor moment on Instagram or Facebook.</span></li>
    <li><span class="num">2</span><span>Tag <span class="bj-tag-pill teal">@brightjulyAU</span></span></li>
    <li><span class="num">3</span><span>Include <span class="bj-tag-pill">#brightjulyAU</span></span></li>
    <li><span class="num">4</span><span>Submit your entry through the <a href={formHref}>form</a>.</span></li>
  </ol>
</div>
