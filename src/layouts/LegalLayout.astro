---
import { Icon } from "astro-icon/components";
import Layout from "./Layout.astro";

export interface Props {
  title: string;
  description?: string;
  canonical?: string;
  heading: string;
  updated?: string;
}
const { title, description, canonical, heading, updated } = Astro.props;
---

<Layout title={title} description={description} canonical={canonical}>
  <div class="bj-page" style="min-height:100vh">
    {/* Header */}
    <header class="border-b" style="border-color:var(--color-line);background:rgba(250,246,239,0.92);backdrop-filter:blur(10px)">
      <div class="max-w-7xl mx-auto px-6 md:px-10 h-16 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2 text-sm tracking-wide" style="color:var(--color-charcoal)">
          <Icon name="lucide:sun" class="w-4 h-4" style="color:var(--color-amber-deep)" />
          <span class="serif text-lg">Bright July</span>
        </a>
        <a href="/" class="inline-flex items-center gap-2 text-xs tracking-widest uppercase" style="color:var(--color-muted)">
          <Icon name="lucide:arrow-left" class="w-3.5 h-3.5" /> Back Home
        </a>
      </div>
    </header>

    <section class="py-20 md:py-24">
      <div class="max-w-3xl mx-auto px-6 md:px-10">
        <h1 class="text-4xl md:text-5xl leading-[1.04]">{heading}</h1>
        {updated && <p class="mt-3 text-sm" style="color:var(--color-muted)">Last Updated: {updated}</p>}
        <article class="bj-legal mt-12">
          <slot />
        </article>
      </div>
    </section>

    {/* Footer */}
    <footer class="py-12" style="background:var(--color-charcoal);color:rgba(250,246,239,0.7)">
      <div class="max-w-7xl mx-auto px-6 md:px-10 flex flex-col md:flex-row items-center justify-between gap-4 text-sm">
        <div class="flex items-baseline gap-3">
          <span class="serif text-lg" style="color:var(--color-cream)">Bright July</span>
          <span class="text-xs tracking-[0.22em] uppercase">A Family Outdoor Movement</span>
        </div>
        <div class="flex items-center gap-6 text-xs">
          <a href="/competition-terms" class="hover:text-white">Competition Terms</a>
          <a href="/privacy" class="hover:text-white">Privacy Policy</a>
          <a href="/terms" class="hover:text-white">Website Terms</a>
        </div>
      </div>
    </footer>
  </div>
</Layout>

<style is:global>
  .bj-legal {
    color: var(--color-ink);
    font-size: 1.0625rem;
    line-height: 1.8;
  }
  .bj-legal > * + * { margin-top: 1.75rem; }
  .bj-legal h2 {
    font-family: var(--font-serif);
    color: var(--color-charcoal);
    font-size: 1.5rem;
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
  }
  .bj-legal h3 {
    font-family: var(--font-serif);
    color: var(--color-charcoal);
    font-size: 1.25rem;
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
  }
  .bj-legal p { margin-top: 1rem; }
  .bj-legal ul, .bj-legal ol { margin-top: 1rem; padding-left: 0; list-style: none; }
  .bj-legal li { display: flex; gap: 0.75rem; align-items: flex-start; margin-top: 0.5rem; }
  .bj-legal ul li::before {
    content: "";
    width: 6px;
    height: 6px;
    border-radius: 999px;
    background: var(--color-teal);
    flex-shrink: 0;
    margin-top: 0.7rem;
  }
  .bj-legal ol { counter-reset: legal; }
  .bj-legal ol li { counter-increment: legal; }
  .bj-legal ol li::before {
    content: "(" counter(legal, lower-alpha) ")";
    color: var(--color-teal);
    font-weight: 600;
    flex-shrink: 0;
    min-width: 1.5rem;
  }
  .bj-legal a { color: var(--color-amber-deep); text-decoration: underline; text-underline-offset: 2px; }
  .bj-legal strong { color: var(--color-charcoal); }
</style>
