---
import { Image } from "astro:assets";
import { Icon } from "astro-icon/components";
import Layout from "../layouts/Layout.astro";
import TagCallout from "../components/TagCallout.astro";
import PodcastEpisode from "../components/PodcastEpisode.astro";
import Nav from "../components/Nav.astro";
import {
  hero,
  closing,
  lifestyle,
  johnPortrait,
  luxiLogo,
  zeissLogo,
  prizeSunglasses1,
  prizeSunglasses2,
  social1,
  social2,
  social3,
  social4,
  social5,
  social6,
  social7,
  social8,
  ideaPuddle,
  ideaClouds,
} from "../data/images.ts";

const SHARE_URL = "https://brightjuly.com.au/";
const SHARE_TEXT =
  "Join the Bright July family movement, getting outdoors together this winter.";

const whyStats = [
  { n: "2 Hours", l: "Outdoor time per day shown to reduce myopia risk by up to 50%." },
  { n: "#1 Source", l: "Of vitamin D for growing children." },
  { n: "Better Sleep", l: "Natural light anchors your child's body clock." },
];

const steps = [
  {
    n: "01",
    icon: "lucide:user-plus",
    title: "Make a Pledge",
    d: "Set a total outdoor time goal for July as a family, for example, two hours a day or fifty hours across the month, and write it down together as a shared commitment.",
    cta: "Write down your pledge",
    href: null as string | null,
  },
  {
    n: "02",
    icon: "lucide:calendar-check",
    title: "Get Outside",
    d: "Spend time outdoors together throughout the week, before school, after work, on weekends, and capture your favourite family moments along the way with a quick photo or short video.",
    cta: "See ideas",
    href: "#ideas",
  },
  {
    n: "03",
    icon: "lucide:gift",
    title: "Submit & Win",
    d: "Share your outdoor moment on Facebook or Instagram using #BrightJuly and tag @BrightJuly, then enter the weekly prize draw via the entry form.",
    cta: "Enter to win",
    href: "/competition",
  },
];

const faqs = [
  { q: "Who can enter the Bright July competition?", a: "Any Australian family. Parents or guardians enter on behalf of their household." },
  { q: "How do I enter?", a: "First, make a pledge as a family and write it down together, a simple shared commitment for the month. Then submit a weekly entry via the form on the competition page. Using #BrightJuly on social posts is encouraged but not compulsory, if you'd prefer to enter privately, just provide a caption and a screenshot of your private post (screenshot optional)." },
  { q: "How are entries judged?", a: "Entries are judged, not randomly drawn, based on creativity, authentic family participation, alignment with the Bright July mission, storytelling, and the most creative outdoor journey." },
  { q: "Can I enter privately without posting on social media?", a: "Yes. For private entries, just provide a caption and a screenshot of your private post (screenshot optional) via the entry form. The #BrightJuly hashtag is encouraged but not required." },
  { q: "Can I submit more than once?", a: "Yes. You're encouraged to submit a new entry each week of the campaign." },
  { q: "When are winners announced?", a: "Winners are announced on the Monday of the following week after each submission deadline." },
  { q: "Is there a cost to join?", a: "No. Bright July is free for every family, make your pledge, log your moments, and share if you like." },
  { q: "What about photos of my children?", a: "Only share what you're comfortable with. See our Privacy Policy and Competition T&Cs for full details." },
];

// To embed ahead of release: schedule each episode as a YouTube Premiere, then paste its
// 11-char video ID into `videoId`. The card shows the native premiere countdown and goes
// live automatically at air time, no redeploy needed. Leave "" to show the placeholder.
const episodes = [
  { n: "01", date: "Mon 6 July", title: "Why outdoor light matters", d: "How daily outdoor time supports children's eye wellness.", featured: true, videoId: "" },
  { n: "02", date: "Mon 13 July", title: "Building brighter habits", d: "Practical ways families can create more outdoor moments.", featured: false, videoId: "" },
  { n: "03", date: "Mon 20 July", title: "Research made simple", d: "What the latest eye wellness research means for parents.", featured: false, videoId: "" },
  { n: "04", date: "Mon 27 July", title: "From clinic to home", d: "Optometry voices on supporting children beyond the clinic.", featured: false, videoId: "" },
];

const ideas = [
  { tag: "Winter Picnic", icon: "lucide:snowflake", title: "Winter park picnic", d: "Pack a thermos, a blanket and one favourite snack. Twenty minutes outside, hot chocolate at home. Small ritual, big lift.", img: social8 },
  { tag: "After School", icon: "lucide:sunrise", title: "After-school sunlight walk", d: "Take the long way home for fifteen minutes of daylight before screens take over the afternoon.", img: social3 },
  { tag: "Backyard", icon: "lucide:trees", title: "Backyard treasure hunt", d: "Five things to find: a feather, a smooth stone, something yellow, a fallen leaf, a bug. Kids lead, you follow.", img: social6 },
  { tag: "Weekend Walk", icon: "lucide:waves", title: "Weekend harbour or beach walk", d: "An unhurried Saturday wander along the water. Bonus points for stopping to skim stones or chase seagulls.", img: social2 },
  { tag: "On Wheels", icon: "lucide:bike", title: "Scooter or bike loop", d: "Pick a safe local block, set a 20-minute timer and let the kids do as many loops as they like. Pure outdoor energy.", img: social4 },
  { tag: "Farm Visit", icon: "lucide:trees", title: "Meet the animals at a local farm", d: "Spend a slow morning at a city farm or petting zoo. Fresh air, friendly animals and stories the kids will retell all week.", img: social1 },
  { tag: "15–30 Minutes · Rain-Friendly", icon: "lucide:cloud-rain", title: "🌧️ Puddle Walk Adventure", d: "Who says rainy days have to be spent indoors? Pull on your gumboots, zip up your raincoat and head outside to explore. Challenge your family to find the biggest puddle, make the biggest splash or discover hidden pathways after the rain.", img: ideaPuddle },
  { tag: "Nature Discovery · All Ages", icon: "lucide:cloud", title: "☁️ Rainy Day Explorer Challenge", d: "Slow down and notice the world around you. Listen to raindrops on leaves and rooftops, search the sky for cloud shapes and keep a simple outdoor journal of what you discover. Can your family spot an animal-shaped cloud or hear three different sounds of rain?", img: ideaClouds },
];

const bigQuotes = [
  { q: "Logging our outdoor time made it feel real. The kids started asking to go to the park.", a: "Adam · Adelaide" },
  { q: "I didn't realise how much our weekends had moved indoors until this month.", a: "Nina · Sydney" },
  { q: "Our squad with the cousins kept us showing up, even on the grey weeks.", a: "Chien · Perth" },
];

const socials = [
  { Icon: "lucide:facebook", label: "Bright July on Facebook", href: "https://www.facebook.com/brightjuly" },
  { Icon: "lucide:instagram", label: "Bright July on Instagram", href: "https://www.instagram.com/brightjuly" },
  {
    Icon: "lucide:mail",
    label: "Email Bright July",
    href: `mailto:hello@brightjuly.com.au?subject=${encodeURIComponent("Join us for Bright July")}&body=${encodeURIComponent(SHARE_TEXT + " " + SHARE_URL)}`,
  },
];

const communityTiles = [social5, social2, social3, social4, social1, social6, social7, social8];
const movementTiles = [social1, social5, social7];

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: { "@type": "Answer", text: f.a },
  })),
};
---

<Layout
  title="Bright July | Kids Outside This Winter for Healthier Eyes"
  description="Join Australian families this July. Get kids outside in natural light, reduce myopia risk and win prizes. Free to enter. Register your family today."
  canonical="/"
  schema={[faqSchema]}
>
  <main class="bj-page">
    {/* Sticky Nav */}
    <Nav
      brandHref="#top"
      links={[
        { label: "How It Works", href: "#how" },
        { label: "Outdoor Ideas", href: "#ideas" },
        { label: "Community", href: "#community" },
        { label: "Competition", href: "/competition" },
      ]}
      cta={{ label: "Enter The Challenge", href: "/competition" }}
    />

    {/* Hero */}
    <section id="top" class="relative min-h-[72svh] md:min-h-[78svh] w-full overflow-hidden flex items-end">
      <div class="absolute inset-0">
        <Image
          src={hero}
          alt="A family walking together through a sunlit park at golden hour"
          loading="eager"
          fetchpriority="high"
          widths={[768, 1280, 1920]}
          sizes="100vw"
          class="bj-hero-img w-full h-full object-cover object-[58%_45%] md:object-center"
          style="will-change:transform;filter:brightness(1.18) saturate(1.12) contrast(1.04)"
        />
        <div class="absolute inset-0" style="background:linear-gradient(180deg, rgba(20,16,12,0.30) 0%, rgba(20,16,12,0.12) 45%, rgba(20,16,12,0.58) 100%)"></div>
        <div class="absolute inset-0" style="background:linear-gradient(90deg, rgba(20,16,12,0.40) 0%, rgba(20,16,12,0.0) 70%)"></div>
      </div>
      <div class="relative z-10 w-full max-w-7xl mx-auto px-6 md:px-10 pb-10 md:pb-14 pt-24 md:pt-28">
        <div class="max-w-3xl">
          <p class="bj-fadeup" style="color:rgba(255,255,255,0.95);font-size:11px;letter-spacing:0.28em;text-transform:uppercase;font-weight:600;text-shadow:0 2px 12px rgba(0,0,0,0.5)">
            A National Family Movement · July 2026
          </p>
          <h1 class="bj-fadeup d1 mt-5 text-[3rem] sm:text-7xl md:text-8xl leading-[0.98]" style="color:#ffffff;text-shadow:0 1px 0 rgba(0,0,0,0.4), 0 2px 0 rgba(0,0,0,0.35), 0 3px 0 rgba(0,0,0,0.3), 0 4px 0 rgba(0,0,0,0.25), 0 6px 18px rgba(0,0,0,0.55), 0 12px 40px rgba(0,0,0,0.5)">
            This July<br />Belongs Outside.
          </h1>
          <p class="bj-fadeup d2 mt-8 text-white text-lg md:text-2xl max-w-2xl leading-relaxed font-medium" style="text-shadow:0 2px 10px rgba(0,0,0,0.7), 0 1px 2px rgba(0,0,0,0.6)">
            Join families across Australia building more intentional outdoor light habits.
          </p>
          <p class="bj-fadeup d3 mt-5 text-white/90 text-base md:text-lg max-w-2xl leading-relaxed italic" style="text-shadow:0 2px 10px rgba(0,0,0,0.7)">
            We're doing this during Australia's coldest month, a simple reminder to get outside, get moving and make memories together.
          </p>
          <div class="bj-fadeup d4 mt-10 flex flex-col sm:flex-row gap-3">
            <a href="/competition" class="bj-btn-amber inline-flex items-center justify-center px-8 py-4 rounded-full text-base font-semibold tracking-wide" data-analytics="CTA Click" data-analytics-location="hero">
              Enter The Challenge
            </a>
            <a href="#how" class="inline-flex items-center justify-center px-8 py-4 rounded-full text-base font-semibold tracking-wide" style="color:#fff;border:1px solid rgba(255,255,255,0.5)">
              How It Works
            </a>
          </div>
        </div>
      </div>
    </section>

    {/* SPONSORS */}
    <section id="sponsors" class="py-8 md:py-10" style="background:#FFFDF8;border-bottom:1px solid var(--color-line)">
      <div class="max-w-7xl mx-auto px-6 md:px-10">
        <div class="text-center mb-5">
          <span class="bj-eyebrow">Proudly Supported By</span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 md:gap-6 items-stretch">
          <a href="https://luxihealth.com.au/" target="_blank" rel="noopener noreferrer" aria-label="Visit Luxi Health" class="rounded-2xl flex items-center justify-center py-5 px-6 bg-white transition hover:shadow-md" style="border:1px solid var(--color-line)">
            <Image src={luxiLogo} alt="Luxi Health, Campaign Host" loading="lazy" class="max-h-16 md:max-h-20 w-auto object-contain" />
          </a>
          <div class="rounded-2xl flex items-center justify-center py-5 px-6 bg-white" style="border:1px solid var(--color-line)">
            <Image src={zeissLogo} alt="ZEISS" loading="lazy" class="max-h-16 md:max-h-20 w-auto object-contain" />
          </div>
          <div class="rounded-2xl flex items-center justify-center py-5 px-6 bg-white" style="border:1px solid var(--color-line)">
            <div class="text-center">
              <div class="serif text-2xl md:text-3xl leading-none" style="color:var(--color-teal-deep)">More Partners</div>
              <div class="mt-2 text-[10px] tracking-[0.22em] uppercase" style="color:var(--color-muted)">Joining Soon</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* WHY IT MATTERS */}
    <section id="why" class="py-24 md:py-36" style="background:#FFFDF8">
      <div class="max-w-7xl mx-auto px-6 md:px-10">
        <div class="max-w-3xl bj-reveal">
          <span class="bj-eyebrow">Why It Matters</span>
          <div class="bj-rule mt-4 mb-7"></div>
          <h2 class="text-4xl md:text-6xl leading-[1.04]">
            Modern family life<br />increasingly happens indoors.
          </h2>
          <p class="mt-7 text-lg md:text-xl leading-[1.7]" style="color:var(--color-ink)">
            Bright July is a simple challenge designed to help families make outdoor time more
            visible, intentional and shared.
          </p>
        </div>

        <div class="mt-16 md:mt-20 grid md:grid-cols-3 gap-5 md:gap-7">
          {whyStats.map((s) => (
            <article class="bj-card rounded-[26px] p-8 md:p-10 bg-white flex flex-col" style="border:1px solid var(--color-line)">
              <div class="serif leading-none" style="color:var(--color-amber-deep);font-size:clamp(2.4rem, 5.2vw, 3.6rem);letter-spacing:-0.02em">
                {s.n}
              </div>
              <p class="mt-6 text-base md:text-lg leading-[1.55]" style="color:var(--color-charcoal)">{s.l}</p>
            </article>
          ))}
        </div>

        <div class="mt-10 flex flex-col sm:flex-row gap-3">
          <a href="/competition" class="bj-btn-amber inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-full text-sm font-semibold tracking-wide">
            Enter The Challenge <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </a>
        </div>
      </div>
    </section>

    {/* JOIN THE MOVEMENT */}
    <section id="movement" class="py-24 md:py-36 bj-teal-grad">
      <div class="max-w-7xl mx-auto px-6 md:px-10">
        <div class="grid md:grid-cols-12 gap-10 md:gap-14 items-center">
          <div class="md:col-span-6 bj-reveal">
            <span class="bj-eyebrow">The Movement</span>
            <div class="bj-rule mt-4 mb-7"></div>
            <h2 class="text-4xl md:text-6xl leading-[1.04]">
              Join The Family<br />Outdoor Light Movement.
            </h2>
            <p class="mt-7 text-lg md:text-xl leading-[1.7]" style="color:var(--color-charcoal)">
              One month. Thousands of outdoor moments.
            </p>
            <p class="mt-4 text-base md:text-lg leading-[1.7]" style="color:var(--color-ink)">
              Families across Australia are tracking outdoor time, sharing adventures and
              building brighter habits together.
            </p>

            <div class="mt-10 flex flex-col sm:flex-row gap-3">
              <a href="/competition" class="bj-btn-amber inline-flex items-center justify-center px-7 py-3.5 rounded-full text-sm font-semibold tracking-wide">
                Enter The Challenge
              </a>
              <a href="#community" class="inline-flex items-center justify-center px-7 py-3.5 rounded-full text-sm font-semibold tracking-wide bg-white" style="color:var(--color-charcoal);border:1px solid var(--color-line)">
                See Families Taking Part
              </a>
            </div>

            <div class="mt-8 max-w-xl">
              <TagCallout />
            </div>
          </div>

          <div class="md:col-span-6">
            <div class="relative rounded-[28px] overflow-hidden shadow-[0_30px_80px_-40px_rgba(31,27,22,0.4)] mb-4">
              <Image
                src={lifestyle}
                alt="An Australian family enjoying outdoor light together"
                loading="lazy"
                widths={[400, 800, 1200]}
                sizes="(min-width: 768px) 50vw, 100vw"
                class="w-full h-[360px] md:h-[460px] object-cover"
              />
            </div>
            <div class="grid grid-cols-3 gap-3 md:gap-4">
              {movementTiles.map((img) => (
                <div class="bj-tile">
                  <Image src={img} alt="Family outdoor moment" loading="lazy" widths={[200, 400]} sizes="33vw" class="w-full h-full object-cover" />
                  <div class="absolute top-2 left-2 inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-medium" style="background:rgba(255,255,255,0.92);color:var(--color-ink)">
                    <Icon name="lucide:hash" class="w-3 h-3" style="color:var(--color-amber-deep)" /> BrightJuly
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* HOW IT WORKS */}
    <section id="how" class="py-24 md:py-36 bj-soft-grad">
      <div class="max-w-7xl mx-auto px-6 md:px-10">
        <div class="max-w-2xl bj-reveal">
          <span class="bj-eyebrow">How Bright July Works</span>
          <div class="bj-rule mt-4 mb-7"></div>
          <h2 class="text-4xl md:text-5xl leading-[1.05]">
            Three Simple Steps.<br />One Brighter Month.
          </h2>
          <p class="mt-6 text-base md:text-lg leading-[1.75]" style="color:var(--color-muted)">
            More daylight, better eyes, calmer evenings and memories your kids will carry for years, all from small outdoor moments woven into the everyday rhythm of July.
          </p>
          <p class="mt-5 flex items-start gap-2 text-sm md:text-base font-semibold" style="color:var(--color-amber-deep)">
            <Icon name="lucide:hash" class="w-4 h-4 mt-1 shrink-0" />
            <span>Share with #BrightJuly and tag @BrightJuly to enter.</span>
          </p>
        </div>

        <div class="mt-10 max-w-xl">
          <TagCallout />
        </div>

        <div class="mt-14 grid md:grid-cols-3 gap-6 md:gap-7">
          {steps.map((s) => {
            const cls = "bj-card rounded-[22px] p-7 md:p-8 bg-white block group";
            const Tag = s.href ? "a" : "div";
            return (
              <Tag class={cls} style="border:1px solid var(--color-line)" {...(s.href ? { href: s.href } : {})}>
                <div class="flex items-start justify-between">
                  <span class="bj-step-num">{s.n}</span>
                  <span class="inline-flex items-center justify-center w-10 h-10 rounded-full" style="background:var(--color-amber-soft);color:var(--color-amber-deep)">
                    <Icon name={s.icon} class="w-5 h-5" />
                  </span>
                </div>
                <h3 class="mt-6 text-xl md:text-[1.4rem]">{s.title}</h3>
                <p class="mt-3 text-sm leading-relaxed" style="color:var(--color-muted)">{s.d}</p>
                <span class="bj-link-cta mt-5 inline-flex items-center gap-2 text-sm font-semibold" style="color:var(--color-amber-deep)">
                  {s.cta} {s.href && <Icon name="lucide:arrow-right" class="w-4 h-4" />}
                </span>
              </Tag>
            );
          })}
        </div>

        <div class="mt-10 flex flex-wrap items-center gap-x-7 gap-y-3 text-sm" style="color:var(--color-muted)">
          <a href="/competition-terms" class="underline-offset-4 hover:underline">Competition T&amp;Cs</a>
          <a href="/privacy" class="underline-offset-4 hover:underline">Privacy Policy</a>
        </div>

        <div class="mt-10 max-w-3xl space-y-3">
          <h3 class="text-xl md:text-2xl" style="color:var(--color-charcoal)">Competition FAQ</h3>
          {faqs.map((item) => (
            <details class="group rounded-2xl bg-white p-5 md:p-6" style="border:1px solid var(--color-line)">
              <summary class="flex items-center justify-between cursor-pointer list-none text-base md:text-lg font-semibold" style="color:var(--color-charcoal)">
                {item.q}
                <Icon name="lucide:chevron-down" class="w-5 h-5 transition-transform group-open:rotate-180" style="color:var(--color-amber-deep)" />
              </summary>
              <p class="mt-3 text-sm md:text-base leading-relaxed" style="color:var(--color-muted)">{item.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    {/* THE PRIZE */}
    <section id="prize" class="py-24 md:py-36" style="background:#FFFDF8">
      <div class="max-w-7xl mx-auto px-6 md:px-10">
        <div class="grid md:grid-cols-2 gap-10 md:gap-14 items-center">
          <div class="bj-reveal">
            <span class="bj-eyebrow">The Prize</span>
            <div class="bj-rule mt-4 mb-7"></div>
            <h2 class="text-4xl md:text-5xl leading-[1.05]">Win premium sunglasses,<br />every week of July.</h2>
            <p class="mt-6 text-base md:text-lg leading-[1.75]" style="color:var(--color-muted)">
              Two pairs of premium sunglasses are awarded each week for the most creative family
              outdoor moments. Four weeks, eight pairs, plenty of reasons to get outside together.
            </p>
            <a href="/competition" class="bj-btn-amber mt-8 inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-full text-sm font-semibold tracking-wide" data-analytics="CTA Click" data-analytics-location="prize">
              Enter The Challenge <Icon name="lucide:arrow-right" class="w-4 h-4" />
            </a>
          </div>
          <div class="grid gap-4 md:gap-5 bj-reveal">
            <Image src={prizeSunglasses1} alt="Premium Ray-Ban sunglasses prize" loading="lazy" widths={[400, 800]} sizes="(min-width: 768px) 42vw, 90vw" class="w-full h-auto rounded-[22px] bg-white" style="border:1px solid var(--color-line)" />
            <Image src={prizeSunglasses2} alt="Premium kids' Ray-Ban sunglasses prize" loading="lazy" widths={[400, 800]} sizes="(min-width: 768px) 42vw, 90vw" class="w-full h-auto rounded-[22px] bg-white" style="border:1px solid var(--color-line)" />
          </div>
        </div>
      </div>
    </section>

    {/* PODCAST */}
    <section id="podcast" class="bj-podcast">
      <div class="bj-podcast-glow"></div>
      <div class="bj-podcast-container">
        <div class="bj-podcast-intro">
          <span class="bj-podcast-eyebrow">Bright July Podcast</span>
          <h2>Outdoor light, eye wellness, and brighter family habits.</h2>
          <p>
            Four short video episodes dropping every Monday in July, featuring experts in
            eye wellness sharing simple, practical insights for families.
          </p>
        </div>

        <div class="bj-episode-grid">
          {episodes.map((ep) => <PodcastEpisode {...ep} />)}
        </div>
      </div>
    </section>

    {
      episodes.some((ep) => ep.videoId) && (
        <script is:inline>
          {`document.querySelectorAll('.bj-yt-facade').forEach(function(el){el.addEventListener('click',function(e){e.preventDefault();var src=el.getAttribute('data-embed');if(!src)return;var f=document.createElement('iframe');f.src=src;f.title='YouTube video player';f.loading='lazy';f.allow='accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share';f.allowFullscreen=true;f.style.cssText='width:100%;aspect-ratio:16/9;min-height:190px;border:0;display:block';el.replaceWith(f);});});`}
        </script>
      )
    }

    {/* DIGITAL COMMUNITY */}
    <section id="community" class="py-24 md:py-36 bj-teal-grad">
      <div class="max-w-7xl mx-auto px-6 md:px-10">
        <div class="max-w-2xl bj-reveal">
          <span class="bj-eyebrow">Join The Movement Online</span>
          <div class="bj-rule mt-4 mb-7"></div>
          <h2 class="text-4xl md:text-5xl leading-[1.05]">#BrightJuly</h2>
          <p class="mt-6 text-base md:text-lg leading-[1.75]" style="color:var(--color-ink)">
            Bright July lives in your feed, your podcast app and your group chat, wherever your
            family already gathers online.
          </p>
        </div>

        <div class="mt-8 max-w-xl">
          <TagCallout />
        </div>

        <div class="mt-14 grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-5">
          {communityTiles.map((img) => (
            <div class="bj-tile">
              <Image src={img} alt="Family outdoor moment" loading="lazy" widths={[300, 600]} sizes="(min-width: 768px) 25vw, 50vw" class="w-full h-full object-cover" />
              <div class="absolute inset-0" style="background:linear-gradient(180deg, rgba(0,0,0,0) 55%, rgba(0,0,0,0.35) 100%)"></div>
              <div class="absolute top-3 left-3 inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-medium" style="background:rgba(255,255,255,0.92);color:var(--color-ink)">
                <Icon name="lucide:hash" class="w-3 h-3" style="color:var(--color-amber-deep)" /> BrightJuly
              </div>
            </div>
          ))}
        </div>

        <div class="mt-12 flex flex-wrap items-center gap-4">
          <div class="inline-flex items-center gap-3 px-5 py-3 rounded-full" style="background:#fff;border:1px solid var(--color-line)">
            <Icon name="lucide:hash" class="w-4 h-4" style="color:var(--color-amber-deep)" />
            <span class="serif text-xl" style="color:var(--color-charcoal)">BrightJuly</span>
            <span class="text-xs" style="color:var(--color-muted)">· one photo, one sentence, one shared tag</span>
          </div>
          <a href="/competition" class="bj-btn-amber inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-full text-sm font-semibold tracking-wide">
            Join The Movement <Icon name="lucide:arrow-right" class="w-4 h-4" />
          </a>
        </div>
      </div>
    </section>

    {/* OUTDOOR IDEAS & TIPS */}
    <section id="ideas" class="py-24 md:py-36" style="background:#FFFDF8">
      <div class="max-w-7xl mx-auto px-6 md:px-10">
        <div class="max-w-2xl mb-12 bj-reveal">
          <span class="bj-eyebrow">Outdoor Ideas &amp; Tips</span>
          <div class="bj-rule mt-4 mb-7"></div>
          <h2 class="text-4xl md:text-5xl leading-[1.05]">
            Simple winter ideas,<br />curated for busy families.
          </h2>
          <p class="mt-6 text-base md:text-lg leading-[1.75]" style="color:var(--color-muted)">
            A handpicked collection from the Bright July team, small, doable outdoor moments
            you can fit into the week, even when the weather isn't perfect.
          </p>
        </div>

        <div class="grid md:grid-cols-3 gap-6 md:gap-7">
          {ideas.map((card) => (
            <article class="bj-card rounded-[22px] overflow-hidden bg-white flex flex-col" style="border:1px solid var(--color-line)">
              <div class="aspect-[4/3] overflow-hidden">
                <Image src={card.img} alt={card.title} loading="lazy" widths={[400, 800]} sizes="(min-width: 768px) 33vw, 100vw" class="w-full h-full object-cover" />
              </div>
              <div class="p-6 md:p-7 flex flex-col flex-1">
                <span class="inline-flex self-start items-center gap-2 px-2.5 py-1 rounded-full text-[10px] font-semibold tracking-wider uppercase" style="background:var(--color-teal-pale);color:var(--color-teal-deep)">
                  <Icon name={card.icon} class="w-3 h-3" /> {card.tag}
                </span>
                <h3 class="mt-4 text-xl leading-snug">{card.title}</h3>
                <p class="mt-3 text-sm leading-relaxed" style="color:var(--color-muted)">{card.d}</p>
              </div>
            </article>
          ))}
        </div>

        <div class="mt-12 flex flex-col items-center gap-6">
          <a href="/competition" class="bj-btn-amber inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-full text-sm font-semibold tracking-wide">
            Share Your Outdoor Moment
          </a>
        </div>
      </div>
    </section>

    {/* WHAT FAMILIES TELL US */}
    <section class="py-24 md:py-36 relative overflow-hidden" style="background:var(--color-cream-soft)">
      <div aria-hidden="true" class="serif pointer-events-none select-none absolute -top-10 -left-4 md:-top-16 md:left-6 text-[260px] md:text-[420px] leading-none" style="color:var(--color-amber);opacity:0.08;font-family:var(--font-serif)">
        "
      </div>

      <div class="max-w-7xl mx-auto px-6 md:px-10 relative">
        <div class="max-w-xl bj-reveal">
          <span class="bj-eyebrow">What Families Tell Us</span>
          <div class="bj-rule mt-4 mb-7"></div>
          <h2 class="text-4xl md:text-5xl leading-[1.05]">Small Shifts.<br />Lasting Moments.</h2>
        </div>

        <div class="mt-16 grid md:grid-cols-12 gap-8 md:gap-10 items-start">
          <figure class="md:col-span-7">
            <blockquote class="serif text-3xl md:text-[2.6rem] leading-[1.15]" style="color:var(--color-charcoal);font-family:var(--font-serif)">
              It felt less like a challenge and more like permission to be outside more, together.
            </blockquote>
            <figcaption class="mt-8 flex items-center gap-4">
              <span class="w-10 h-10 rounded-full inline-flex items-center justify-center" style="background:var(--color-amber-soft);color:var(--color-amber-deep)">
                <Icon name="lucide:heart" class="w-4 h-4" />
              </span>
              <span class="text-xs tracking-[0.18em] uppercase" style="color:var(--color-muted)">John · Dad Of Two · Sydney</span>
            </figcaption>
          </figure>

          <div class="md:col-span-5 space-y-5">
            {bigQuotes.map((t) => (
              <figure class="rounded-[18px] p-6 md:p-7 bg-white" style="border:1px solid var(--color-line)">
                <blockquote class="text-base md:text-lg leading-[1.55]" style="color:var(--color-ink)">"{t.q}"</blockquote>
                <figcaption class="mt-5 text-[11px] tracking-[0.18em] uppercase" style="color:var(--color-muted)">{t.a}</figcaption>
              </figure>
            ))}
          </div>
        </div>

        <div class="mt-14 flex flex-col items-center gap-3">
          <a href="/competition" class="bj-btn-amber inline-flex items-center justify-center gap-2 px-7 py-3.5 rounded-full text-sm font-semibold tracking-wide">
            Enter The Challenge
          </a>
        </div>
      </div>
    </section>

    {/* FOUNDER STORY */}
    <section id="story" class="py-24 md:py-36" style="background:var(--color-cream)">
      <div class="max-w-5xl mx-auto px-6 md:px-10">
        <div class="grid md:grid-cols-12 gap-10 md:gap-14 items-center">
          <div class="md:col-span-4 flex justify-center md:justify-start">
            <div class="relative">
              <div class="absolute -inset-3 rounded-full" style="background:var(--color-amber-soft);opacity:0.6;filter:blur(8px)"></div>
              <Image
                src={johnPortrait}
                alt="John Nguyen, Bright July founder"
                loading="lazy"
                width={256}
                height={256}
                class="relative w-48 h-48 md:w-64 md:h-64 rounded-full object-cover shadow-[0_20px_50px_-20px_rgba(31,27,22,0.4)]"
                style="border:4px solid #fff"
              />
            </div>
          </div>
          <div class="md:col-span-8">
            <Icon name="lucide:sparkles" class="w-6 h-6" style="color:var(--color-amber-deep)" />
            <h2 class="mt-5 text-3xl md:text-5xl leading-[1.08]">
              A note from the family<br />who started this.
            </h2>
            <div class="mt-7 space-y-5 text-base md:text-lg leading-[1.85]" style="color:var(--color-ink)">
              <p class="bj-dropcap">
                Bright July began as a small experiment in our own home. A month of saying yes to
                the park a little more often. A month of putting shoes on instead of opening the
                laptop.
              </p>
              <p>
                What we found surprised us. Quieter dinners. Better sleep. And a habit, outdoor
                light, that quietly shapes so much of how our family feels.
              </p>
              <p>
                Bright July is our yearly invitation to other families: make your pledge as a
                family, get outside together, and build a brighter habit one week at a time.
              </p>
              <p style="color:var(--color-muted)">John Nguyen, Bright July founder · parent of two</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* CLOSING CTA */}
    <section class="relative overflow-hidden">
      <div class="absolute inset-0">
        <Image src={closing} alt="Families silhouetted at sunset in an open meadow" loading="lazy" widths={[768, 1280, 1920]} sizes="100vw" class="w-full h-full object-cover object-[62%_42%] md:object-center" />
        <div class="absolute inset-0" style="background:linear-gradient(180deg, rgba(31,27,22,0.15) 0%, rgba(31,27,22,0.35) 100%)"></div>
      </div>
      <div class="relative z-10 max-w-5xl mx-auto px-6 md:px-10 py-32 md:py-44 text-center">
        <Icon name="lucide:sun" class="w-7 h-7 mx-auto" style="color:var(--color-amber)" />
        <h2 class="serif text-5xl md:text-7xl leading-[1.02] text-white mt-8">
          Build a brighter<br />outdoor habit, together.
        </h2>
        <p class="mt-7 max-w-xl mx-auto text-white/85 text-base md:text-lg leading-relaxed">
          Join Australian families turning outdoor light into a simple, shared family ritual
          this July.
        </p>
        <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-3">
          <a href="/competition" class="bj-btn-amber inline-flex items-center justify-center px-8 py-4 rounded-full text-sm font-medium tracking-wide" data-analytics="CTA Click" data-analytics-location="closing">
            Enter The Challenge
          </a>
          <a href="#how" class="inline-flex items-center justify-center px-8 py-4 rounded-full text-sm font-medium tracking-wide" style="color:#fff;border:1px solid rgba(255,255,255,0.4)">
            See How It Works
          </a>
        </div>
      </div>
    </section>

    {/* SOCIAL SHARE WIDGET */}
    <section class="py-14" style="background:var(--color-cream-soft);border-top:1px solid var(--color-line)">
      <div class="max-w-5xl mx-auto px-6 md:px-10">
        <div class="flex flex-col md:flex-row items-center justify-between gap-5">
          <div class="flex items-center gap-3 text-center md:text-left">
            <Icon name="lucide:share-2" class="w-5 h-5" style="color:var(--color-amber-deep)" />
            <div>
              <div class="serif text-xl md:text-2xl" style="color:var(--color-charcoal)">Spread the brightness</div>
              <div class="text-sm" style="color:var(--color-muted)">Help another family join the movement this July.</div>
            </div>
          </div>
          <div class="flex items-center gap-2">
            {socials.map((s) => (
              <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label} class="w-11 h-11 rounded-full inline-flex items-center justify-center bg-white hover:-translate-y-0.5 transition-transform" style="border:1px solid var(--color-line);color:var(--color-charcoal)">
                <Icon name={s.Icon} class="w-4 h-4" />
              </a>
            ))}
          </div>
        </div>
        <div class="mt-8 flex justify-center md:justify-end">
          <TagCallout />
        </div>
      </div>
    </section>

    {/* Footer */}
    <footer class="py-12" style="background:var(--color-charcoal);color:rgba(250,246,239,0.7)">
      <div class="max-w-7xl mx-auto px-6 md:px-10 flex flex-col md:flex-row items-center justify-between gap-4 text-sm">
        <div class="flex items-baseline gap-3">
          <span class="serif text-lg" style="color:var(--color-cream)">Bright July</span>
          <span class="text-xs tracking-[0.22em] uppercase">A Family Outdoor Movement</span>
        </div>
        <div class="flex items-center gap-6 text-xs">
          <a href="/competition-terms" class="hover:text-white">Competition Terms</a>
          <a href="/privacy" class="hover:text-white">Privacy Policy</a>
          <a href="/terms" class="hover:text-white">Website Terms</a>
        </div>
      </div>
    </footer>
  </main>
</Layout>
